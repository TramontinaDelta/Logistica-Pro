// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: routes
// Document ID: auto-generated
// Fields:
//   - routeNumber: string (required)
//   - type: string (required, 'nova', 'antiga', or 'final_mes')
//   - cargoType: string (required, 'plastico', 'porcelana', or 'consolidado')
//   - deliveries: list (required, list of objects)
//   - releasedToLoading: boolean (optional)
//   - createdAt: number or timestamp (required)
//   - createdBy: string (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidRoute(data) {
      return data.keys().hasAll(['routeNumber', 'type', 'cargoType', 'deliveries', 'createdAt', 'createdBy']) &&
             data.routeNumber is string && data.routeNumber.size() > 0 &&
             data.type in ['nova', 'antiga', 'final_mes'] &&
             data.cargoType in ['plastico', 'porcelana', 'consolidado'] &&
             data.deliveries is list &&
             (!('releasedToLoading' in data) || data.releasedToLoading is bool) &&
             (data.createdAt is number || data.createdAt is timestamp) &&
             data.createdBy is string && data.createdBy == request.auth.uid;
    }

    match /routes/{routeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoute(request.resource.data);
      allow update: if isAuthenticated() && 
                    isValidRoute(request.resource.data) && 
                    resource.data.createdBy == request.auth.uid &&
                    request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
